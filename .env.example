# Optional LLM providers (leave blank for mock/demo mode)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional weather provider base URL (leave blank to use default in code)
OPEN_METEO_BASE_URL=

# Visual Crossing API key (primary weather provider)
VISUAL_CROSSING_API_KEY=

# App environment (e.g., development, test, production)
APP_ENV=

# Force mock/demo behavior when true/1/yes
MOCK_MODE=

# Local project storage directory (file-backed persistence)
PROJECTS_DATA_DIR=
